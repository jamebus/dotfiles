[include]
	path = ~/.config/delta/themes/catppuccin.gitconfig
[user]
	name = {{ .contact.name }}
	email = {{ .contact.email }}
[init]
	defaultBranch = main
[core]
	excludesfile = ~/.gitignore-global
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	features = catppuccin-latte
[merge]
	conflictStyle = zdiff3
